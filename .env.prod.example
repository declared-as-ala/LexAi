# Copy this file to .env.prod on your VPS and fill in real values.
# The .env.prod file is NOT committed to git (see .gitignore).

# ── Database ────────────────────────────────────────────────────────────────────
DB_USER=lexai
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_NAME=legaltech

# ── LLM — Groq (Agent 4 enhanced recommendations) ──────────────────────────────
# Get your key at https://console.groq.com/keys
GROQ_API_KEY=gsk_...
LLM_API_KEY=gsk_...
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama3-70b-8192

# ── App ─────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
MAX_UPLOAD_MB=50
